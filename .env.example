# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# API server
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:8000

# JWT (required for auth)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# Frontend — same-origin proxy in dev (see apps/web/next.config.js rewrites)
# Production (Vercel): set API_INTERNAL_URL=https://chaiform-production.up.railway.app
NEXT_PUBLIC_API_URL=/trpc

# Cloudflare Turnstile CAPTCHA (optional — public form submit)
# Get keys: https://dash.cloudflare.com → Turnstile → Add site
# Set on Vercel (site key + secret) AND Railway (secret + site key for server verify)
# Dev test keys (always pass): site=1x00000000000000000000AA secret=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Email (Resend — optional in dev; links logged to API console without this)
RESEND_API_KEY=
EMAIL_FROM=ChaiForm <onboarding@resend.dev>

# Google OAuth (optional for creator auth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# Logger (optional)
LOGGER_LEVEL=debug

# Redis (optional — shared rate limits + analytics cache across instances)
REDIS_URL=
# Set true only when Redis is configured and submissions should fail closed if Redis is unavailable.
RATE_LIMIT_REQUIRE_REDIS=false

# API docs in production (default true — set false + OPENAPI_DOCS_SECRET to protect /docs)
PUBLIC_OPENAPI_DOCS=true
OPENAPI_DOCS_SECRET=

# Seed script — creates verified demo user + sample form/submissions
SEED_USER_EMAIL=demo@chaiform.dev
SEED_DEMO_PASSWORD=DemoPass123!
# Set true only if the seeded demo user should have admin role (default: regular creator)
SEED_DEMO_ADMIN=false
