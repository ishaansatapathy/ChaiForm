# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dev

# API server
PORT=8000
BASE_URL=http://localhost:8000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT (required for auth)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret

# Frontend — same-origin proxy in dev (see apps/web/next.config.js rewrites)
NEXT_PUBLIC_API_URL=/trpc

# Google OAuth (optional for creator auth)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api-auth/google/callback

# Logger (optional)
LOGGER_LEVEL=debug

# Seed script (optional)
SEED_USER_EMAIL=demo@chaiform.dev
