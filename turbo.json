{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalEnv": [
    "DATABASE_URL",
    "JWT_SECRET",
    "JWT_REFRESH_SECRET",
    "CLIENT_URL",
    "BASE_URL",
    "API_INTERNAL_URL",
    "NODE_ENV",
    "RESEND_API_KEY",
    "EMAIL_FROM",
    "SEED_USER_EMAIL",
    "SEED_DEMO_PASSWORD",
    "VITEST",
    "OPENAPI_DOCS_SECRET",
    "PUBLIC_OPENAPI_DOCS",
    "REDIS_URL",
    "RATE_LIMIT_REQUIRE_REDIS",
    "PORT",
    "CRON_SECRET",
    "DEMO_LOGIN_ENABLED",
    "DEMO_USER_EMAIL",
    "DEMO_USER_PASSWORD",
    "E2E_API_URL",
    "E2E_BASE_URL",
    "E2E_RUN_AUTH_SMOKE",
    "CI"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {},
    "db:migrate": {},
    "db:seed": {},
    "test": {
      "dependsOn": ["^test"]
    }
  }
}
